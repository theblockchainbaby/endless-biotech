generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  plan                 String              @default("free")
  settings             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  currentPeriodEnd     DateTime?
  planStatus           String              @default("active")
  stripeCustomerId     String?             @unique
  stripePriceId        String?
  stripeSubscriptionId String?             @unique
  trialEndsAt          DateTime?
  vesselLimitOverride  Int?
  alerts               Alert[]
  apiKeys              ApiKey[]
  cloneLines           CloneLine[]
  cultivars            Cultivar[]
  incentiveConfig      IncentiveConfig?
  incentivePointRules  IncentivePointRule[]
  inventoryItems       InventoryItem[]
  mediaRecipes         MediaRecipe[]
  pathogenTests        PathogenTest[]
  protocols            Protocol[]
  salesOrders          SalesOrder[]
  shiftNotes           ShiftNote[]
  sites                Site[]
  stations             Station[]
  techShifts           TechShift[]
  users                User[]
  vessels              Vessel[]
  webhookEndpoints     WebhookEndpoint[]
}

model Site {
  id             String       @id @default(cuid())
  name           String
  address        String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  locations      Location[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  emailVerified       DateTime?
  passwordHash        String?
  image               String?
  role                String               @default("tech")
  pin                 String?
  isActive            Boolean              @default(true)
  organizationId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastLogin           DateTime?
  loginCount          Int                  @default(0)
  accounts            Account[]
  activities          Activity[]
  environmentReadings EnvironmentReading[] @relation("ReadingRecordedBy")
  inventoryUsages     InventoryUsage[]     @relation("UsageBy")
  mediaBatches        MediaBatch[]         @relation("MediaPreparer")
  pathogenTests       PathogenTest[]       @relation("TestLoggedBy")
  photos              Photo[]              @relation("PhotoTakenBy")
  sessions            Session[]
  shiftNotes          ShiftNote[]          @relation("ShiftNoteAuthor")
  techShifts          TechShift[]          @relation("TechShiftUser")
  organization        Organization         @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, role])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id                  String               @id @default(cuid())
  name                String
  type                String
  siteId              String
  parentId            String?
  capacity            Int?
  conditions          Json?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  environmentReadings EnvironmentReading[]
  parent              Location?            @relation("LocationHierarchy", fields: [parentId], references: [id])
  children            Location[]           @relation("LocationHierarchy")
  site                Site                 @relation(fields: [siteId], references: [id])
  vessels             Vessel[]

  @@index([siteId])
  @@index([siteId, isActive])
  @@index([parentId])
}

model Cultivar {
  id                       String       @id @default(cuid())
  name                     String
  species                  String       @default("Cannabis")
  strain                   String?
  geneticLineage           String?
  description              String?
  targetMultiplicationRate Float?
  defaultMediaRecipeId     String?
  organizationId           String
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  notes                    String?
  code                     String?
  cultivarType             String       @default("in_house")
  stageConfig              Json?
  cloneLines               CloneLine[]
  defaultMediaRecipe       MediaRecipe? @relation("DefaultRecipe", fields: [defaultMediaRecipeId], references: [id])
  incentivePointRules      IncentivePointRule[]
  organization             Organization @relation(fields: [organizationId], references: [id])
  photos                   Photo[]      @relation("CultivarPhotos")
  salesOrders              SalesOrder[]
  vessels                  Vessel[]

  @@unique([name, organizationId])
  @@unique([code, organizationId])
  @@index([organizationId])
}

model MediaRecipe {
  id                   String           @id @default(cuid())
  name                 String
  baseMedia            String
  targetPH             Float?
  agarConcentration    Float?
  sucroseConcentration Float?
  stage                String?
  notes                String?
  isActive             Boolean          @default(true)
  organizationId       String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  cultivars            Cultivar[]       @relation("DefaultRecipe")
  batches              MediaBatch[]
  components           MediaComponent[]
  organization         Organization     @relation(fields: [organizationId], references: [id])
  vessels              Vessel[]

  @@index([organizationId])
}

model MediaComponent {
  id            String      @id @default(cuid())
  recipeId      String
  name          String
  category      String
  concentration Float
  unit          String      @default("mg/L")
  recipe        MediaRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model MediaBatch {
  id           String      @id @default(cuid())
  batchNumber  String      @unique
  recipeId     String
  volumeL      Float
  vesselCount  Int
  preparedById String?
  measuredPH   Float?
  autoclaved   Boolean     @default(false)
  autoclavedAt DateTime?
  expiresAt    DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  preparedBy   User?       @relation("MediaPreparer", fields: [preparedById], references: [id])
  recipe       MediaRecipe @relation(fields: [recipeId], references: [id])
  vessels      Vessel[]    @relation("BatchVessels")
}

model Vessel {
  id                 String       @id @default(cuid())
  barcode            String       @unique
  cultivarId         String?
  mediaRecipeId      String?
  locationId         String?
  explantCount       Int          @default(0)
  healthStatus       String       @default("healthy")
  status             String       @default("media_filled")
  stage              String       @default("initiation")
  subcultureNumber   Int          @default(0)
  generation         Int          @default(0)
  contaminationType  String?
  contaminationDate  DateTime?
  disposalReason     String?
  notes              String?
  parentVesselId     String?
  organizationId     String
  plantedAt          DateTime?
  nextSubcultureDate DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  mediaBatchId       String?
  lastSubcultureDate DateTime?
  cloneLineId        String?
  explantType        String?
  activities         Activity[]
  photos             Photo[]      @relation("VesselPhotos")
  cloneLine          CloneLine?   @relation(fields: [cloneLineId], references: [id])
  cultivar           Cultivar?    @relation(fields: [cultivarId], references: [id])
  location           Location?    @relation(fields: [locationId], references: [id])
  mediaBatch         MediaBatch?  @relation("BatchVessels", fields: [mediaBatchId], references: [id])
  mediaRecipe        MediaRecipe? @relation(fields: [mediaRecipeId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id])
  parentVessel       Vessel?      @relation("VesselLineage", fields: [parentVesselId], references: [id])
  childVessels       Vessel[]     @relation("VesselLineage")

  @@index([organizationId, status])
  @@index([organizationId, cultivarId])
  @@index([organizationId, stage])
  @@index([organizationId, healthStatus])
  @@index([organizationId, nextSubcultureDate])
  @@index([healthStatus, contaminationType])
  @@index([barcode])
  @@index([locationId])
  @@index([nextSubcultureDate])
  @@index([parentVesselId])
  @@index([cloneLineId])
}

model Activity {
  id            String   @id @default(cuid())
  vesselId      String?
  userId        String?
  type          String
  category      String   @default("vessel")
  previousState Json?
  newState      Json?
  metadata      Json?
  notes         String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  vessel        Vessel?  @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@index([vesselId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([createdAt, vesselId])
  @@index([type, createdAt])
}

model Photo {
  id           String    @id @default(cuid())
  url          String
  thumbnailUrl String?
  vesselId     String?
  cultivarId   String?
  caption      String?
  stage        String?
  takenById    String?
  createdAt    DateTime  @default(now())
  cultivar     Cultivar? @relation("CultivarPhotos", fields: [cultivarId], references: [id])
  takenBy      User?     @relation("PhotoTakenBy", fields: [takenById], references: [id])
  vessel       Vessel?   @relation("VesselPhotos", fields: [vesselId], references: [id])

  @@index([vesselId])
  @@index([cultivarId])
}

model EnvironmentReading {
  id           String   @id @default(cuid())
  locationId   String
  temperature  Float?
  humidity     Float?
  co2Level     Float?
  lightLevel   Float?
  recordedById String?
  recordedAt   DateTime @default(now())
  source       String   @default("manual")
  location     Location @relation(fields: [locationId], references: [id])
  recordedBy   User?    @relation("ReadingRecordedBy", fields: [recordedById], references: [id])

  @@index([locationId, recordedAt])
}

model InventoryItem {
  id              String           @id @default(cuid())
  name            String
  category        String
  sku             String?
  supplier        String?
  currentStock    Float            @default(0)
  unit            String
  reorderLevel    Float?
  costPerUnit     Float?
  storageLocation String?
  expirationDate  DateTime?
  organizationId  String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id])
  usageLogs       InventoryUsage[]

  @@index([organizationId])
}

model InventoryUsage {
  id        String        @id @default(cuid())
  itemId    String
  quantity  Float
  reason    String?
  usedById  String?
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])
  usedBy    User?         @relation("UsageBy", fields: [usedById], references: [id])

  @@index([itemId])
}

model Protocol {
  id             String       @id @default(cuid())
  name           String
  stage          String
  version        Int          @default(1)
  steps          Json
  safetyNotes    String?
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([organizationId, stage])
}

model Alert {
  id             String       @id @default(cuid())
  type           String
  severity       String       @default("info")
  title          String
  message        String
  entityType     String?
  entityId       String?
  isRead         Boolean      @default(false)
  isDismissed    Boolean      @default(false)
  organizationId String
  userId         String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isRead])
  @@index([userId])
}

model CloneLine {
  id             String         @id @default(cuid())
  name           String
  code           String?
  cultivarId     String
  sourceType     String         @default("mother_plant")
  motherPlantId  String?
  startDate      DateTime       @default(now())
  status         String         @default("active")
  notes          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastTestResult String?
  lastTestedAt   DateTime?
  lineNumber     Int?
  cultivar       Cultivar       @relation(fields: [cultivarId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id])
  pathogenTests  PathogenTest[]
  vessels        Vessel[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([cultivarId])
  @@index([status])
}

model SalesOrder {
  id             String       @id @default(cuid())
  orderNumber    String
  customerName   String
  cultivarId     String
  quantity       Int
  unitType       String       @default("plugs")
  dueDate        DateTime
  status         String       @default("pending")
  priority       String       @default("normal")
  notes          String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deliveryType   String       @default("gen_zero_direct")
  productionPlan Json?
  cultivar       Cultivar     @relation(fields: [cultivarId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([orderNumber, organizationId])
  @@index([organizationId])
  @@index([cultivarId])
  @@index([dueDate])
  @@index([status])
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  keyPrefix      String
  permissions    Json
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([keyHash])
}

model WebhookEndpoint {
  id              String       @id @default(cuid())
  url             String
  events          Json
  secret          String
  isActive        Boolean      @default(true)
  lastDeliveredAt DateTime?
  failureCount    Int          @default(0)
  organizationId  String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model PathogenTest {
  id             String       @id @default(cuid())
  cloneLineId    String
  testDate       DateTime
  result         String
  pathogen       String?
  testingId      String?
  labName        String
  assayType      String?
  notes          String?
  loggedById     String?
  organizationId String
  createdAt      DateTime     @default(now())
  cloneLine      CloneLine    @relation(fields: [cloneLineId], references: [id], onDelete: Cascade)
  loggedBy       User?        @relation("TestLoggedBy", fields: [loggedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([cloneLineId])
  @@index([organizationId])
  @@index([testDate])
  @@index([result])
}

// ─── Technician Performance & Incentive System ───────────────────────────────

model IncentiveConfig {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  baseHourlyRate          Float        @default(16.0)
  pointDollarValue        Float        @default(0.025)
  contaminationThreshold  Float        @default(5.0)
  contaminationLookbackDays Int        @default(14)
  bonusPeriod             String       @default("weekly") // daily, weekly, biweekly, monthly
  dailyVesselTarget       Int?
  enableIncentives        Boolean      @default(true)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  organization            Organization @relation(fields: [organizationId], references: [id])
}

model IncentivePointRule {
  id             String       @id @default(cuid())
  organizationId String
  stage          String       // initiation, multiplication, rooting, hardening
  containerType  String       @default("jar") // jar, tube, magenta_box, flask
  taskType       String       @default("transfer") // transfer, initiation, grading, media_prep
  basePoints     Float
  cultivarId     String?      // optional cultivar-specific override
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cultivar       Cultivar?    @relation(fields: [cultivarId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, stage, containerType, taskType, cultivarId])
  @@index([organizationId])
  @@index([organizationId, stage])
}

model Station {
  id             String       @id @default(cuid())
  name           String       // "Hood 1", "Hood 2", "Bench 3"
  type           String       @default("laminar_flow_hood") // laminar_flow_hood, clean_bench, prep_station
  locationId     String?      // optional link to a Location
  isActive       Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  techShifts     TechShift[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([name, organizationId])
  @@index([organizationId])
}

model TechShift {
  id             String       @id @default(cuid())
  userId         String
  stationId      String?
  organizationId String
  clockIn        DateTime
  clockOut       DateTime?
  hoursWorked    Float?       // computed on clock-out
  isOvertime     Boolean      @default(false)
  totalPoints    Float        @default(0)
  vesselsProcessed Int        @default(0)
  contaminationCount Int      @default(0)
  effectiveRate  Float?       // computed: totalPoints * pointDollarValue / hoursWorked
  bonusAmount    Float?       // computed: max(0, effectiveRate - baseHourlyRate) * hoursWorked
  status         String       @default("active") // active, completed, void
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation("TechShiftUser", fields: [userId], references: [id])
  station        Station?     @relation(fields: [stationId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([userId, clockIn])
  @@index([organizationId, clockIn])
  @@index([stationId])
  @@index([status])
}

model ShiftNote {
  id             String       @id @default(cuid())
  authorId       String
  organizationId String
  content        String
  priority       String       @default("normal") // normal, important, urgent
  isRead         Boolean      @default(false)
  shiftDate      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  author         User         @relation("ShiftNoteAuthor", fields: [authorId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, shiftDate])
  @@index([authorId])
}
